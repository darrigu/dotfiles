[global]
offset = (24, 24)

font = JetBrainsMono Nerd Font Mono 10

corner_radius = 4

mouse_left_click = do_action, close_current
mouse_middle_click = close_all
mouse_right_click = close_current

frame_width = 2
frame_color = "#89b4fa"
separator_color= frame
highlight = "#89b4fa"

[experimental]
pause_on_mouse_over = true

[urgency_low]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_normal]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4"
frame_color = "#fab387"
